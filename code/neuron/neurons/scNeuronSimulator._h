class THREADSAFEEVENT_GenComp_type {
public:
    sc_core::sc_event
        // Operation-related
        ClockDown,              // Temporary, to test clocked
        ClockUp,                // operating mode
        ComputingBegin,         // Begin data processing
        ComputingEnd,           // End data processing
        DeliveringBegin,        // Begin delivering the result (internally)
        DeliveringEnd,          // End delivering
        Failed,                 // Computing failed, start over
        Heartbeat,              // Refresh PU's state
        Initialize,             // Put the unit to its ground state
        InputReceived,          // New input received
        RelaxingBegin,          // Begin restoring the 'Ready' state
        RelaxingEnd,            // Begin restoring the 'End' state
        Synchronize,            // External synhronize signal
        TransmissionBegin;      // Begin data transmission
};


/*! \var EVENT_GenComp_type::ClockDown
 * The external clock issued a "down" edge. Triggers scGenComp_PU_Abstract::scClockDown_method()
 */
/*! \var EVENT_GenComp_type::ClockUp
 * The external clock issued an "up" edge. Triggers scGenComp_PU_Abstract::scClockUp_method()
 */
/*! \var EVENT_GenComp_type::ComputingBegin
 *
 * Triggers scGenComp_PU_Abstract::ComputingBegin_method()
 */
/*! \var EVENT_GenComp_type::ComputingEnd
 *
 * Triggers scGenComp_PU_Abstract::ComputingEnd_method()
 */
/*! \var EVENT_GenComp_type::DeliveringBegin
 *
 * Triggers scGenComp_PU_Abstract::DeliveringBegin_method()
 */
/*! \var EVENT_GenComp_type::DeliveringEnd
 *
 * Triggers scGenComp_PU_Abstract::DeliveringEnd_method()
 */
/*! \var EVENT_GenComp_type::Failed
 *
 * Triggers scGenComp_PU_Abstract::Failed_method()
 */
/*! \var EVENT_GenComp_type::Heartbeat
 *
 * Triggers scGenComp_PU_Abstract::Heartbeat_method()
 */
/*! \var EVENT_GenComp_type::Initialize
 *
 * Triggers scGenComp_PU_Abstract::Initialize_method()
 */
/*! \var EVENT_GenComp_type::InputReceived
 *
 * Triggers scGenComp_PU_Abstract::InputReceived_method()
 */
/*! \var EVENT_GenComp_type::RelaxingBegin
 *
 * Triggers scGenComp_PU_Abstract::RelaxingBegin_method()
 */
/*! \var EVENT_GenComp_type::Synchronize
 *
 * Triggers scGenComp_PU_Abstract::Synchronize_method()
 */
/*! \var EVENT_GenComp_type::TransmissionBegin
 *
 * Triggers scGenComp_PU_Abstract::TransmissionBegin_method()
 */

class ThreadSafeEventIf : public sc_interface {
    virtual void notify(sc_time delay = SC_ZERO_TIME) = 0;
    virtual const sc_event &default_event(void) const = 0;
protected:
    virtual void update(void) = 0;
};

class ThreadSafeEvent : public sc_prim_channel, public ThreadSafeEventIf {
public:
    ThreadSafeEvent(const char *name = ""): event(name) {}

    void notify(sc_time delay = SC_ZERO_TIME) {
        this->delay = delay;
        async_request_update();
    }

    const sc_event &default_event(void) const {
        return event;
    }
protected:
    virtual void update(void) {
        event.notify(delay);
    }
    sc_event event;
    sc_time delay;
};


void *externalHostThread(void *arg);

/*!
 * \class scNeuronSimulator
 * \brief  A simple  class to monitorize the operation of an abstract  neuron.
 * The operating principle is that neurons send messages to the main program
 */

class scNeuronSimulator : public sc_core::sc_module
{
public:
    /*!
     * \brief Creates a neuron simulator
     * @param nm the SystemC name of the module
     */
    scNeuronSimulator(sc_core::sc_module_name nm);
private:
    void ComputingBegin_method(void)
    {   NotifyMain(gcob_ObserveComputingBegin); }
    void ComputingEnd_method(void)
    {   NotifyMain(gcob_ObserveComputingEnd); }
    void DeliveringBegin_method(void)
    {   NotifyMain(gcob_ObserveDeliveringBegin); }
    void DeliveringEnd_method(void)
    {   NotifyMain(gcob_ObserveDeliveringEnd); }
    void Failed_method(void)
    {   NotifyMain(gcob_ObserveFailed); }
    void Heartbeat_method(void)
    {   NotifyMain(gcob_ObserveHeartbeat); }
    void InputReceived_method(void)
    {   NotifyMain(gcob_ObserveInputReceived); }
    void RelaxingBegin_method(void)
    {   NotifyMain(gcob_ObserveRelaxingBegin); }
    void RelaxingEnd_method(void)
    {   NotifyMain(gcob_ObserveRelaxingEnd); }
    void Synchronize_method(void)
    {   NotifyMain(gcob_ObserveSynchronize); }
    void main() {
             std::cout << "Beginning" << std::endl; int count = 10;
              while(count--)
    {
        std::cout << "Waiting" << std::endl;
        wait(SC_ZERO_TIME);
        usleep(500 * 1000); // Just for the example, event is added to pending events during this sleep
    }
    std::cout << "Done" << std::endl;
}
    void NotifyMain(GenCompPUObservingBits_t  gcob_Bit)
{
    //    scGenComp_PU_Abstract* Neuron = dynamic_cast<scGenComp_PU_Abstract*>(E.get_parent_object()->get_parent_object());
 //   scGenComp_PU_Abstract* Neuron = dynamic_cast<scGenComp_PU_Abstract*>(EVENT_GenComp.Initialize.get_parent_object()->get_parent_object());
 //   scNeuronSimulator* NeuronSimulator = dynamic_cast<NeuronSimulator*>(EVENT_GenComp.Initialize.get_parent_object()->get_parent_object());
 //   sc_event event* Original = NeuronSimulator->event;

    scGenComp_PU_Abstract* Neuron = dynamic_cast<scGenComp_PU_Abstract*>(EVENT_GenComp.Initialize.get_parent_object());
 //   sc_event* Original = dynamic_cast<sc_event*>NeuronSimulator->event;
    assert(Neuron); // Must be an existing neuron type
    assert(gcob_Bit < gcob_Max);

    std::cout << "Observed event " << name() << "->" << GenCompObserveStrings[gcob_Bit] << " received\n";
}
/*   ClockDown,              // Temporary, to test clocked
        ClockUp,                // operating mode
        TransmissionBegin;      // Begin data transmission
*/
void eventOneTriggered() {
    std::cout << "Got event #1" << std::endl;
}
void eventTwoTriggered() {
    std::cout << "Got event #2" << std::endl;
}
public:
void Initialize_method()
    {
    NotifyMain(gcob_ObserveInitialize);
    }
public:
THREADSAFEEVENT_GenComp_type EVENT_GenComp;
ThreadSafeEvent eventOne;
ThreadSafeEvent eventTwo;
ThreadSafeEvent eventInited;
    virtual ~scNeuronSimulator(void)    {}// Must be overridden

 private:
        /// The event specific to this class
    pthread_t m_thread;
 };// of class scNeuronSimulator


#endif // NEURONSIMULATOR_H
