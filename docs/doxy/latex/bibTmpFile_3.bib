@book{OriginMembranePotential:2017,
	title = {The Origin of the Resting Membrane Potential},
	editor = {Joseph Feher},
	publisher = {Academic Press},
	edition = {Second Edition},
	address = {Boston},
	pages = {255-264},
	year = {2017},
	isbn = {978-0-12-800883-6},
	doi = {https://doi.org/10.1016/B978-0-12-800883-6.00023-9},
	url = {https://www.sciencedirect.com/science/article/pii/B9780128008836000239},
	author = {Joseph Feher},
	keywords = {Equilibrium potential, Nernst Equation, Fick’s Equation, Nernst–Planck Electrodiffusion Equation, Goldman–Hodgkin–Katz Equation, slope conductance, chord conductance, chord},
	abstract = {This chapter shows how the resting membrane potential derives from relative conductances of all permeable ions. It does this by first considering hypothetical membranes that are permeable to single ions. The membrane in each of these cases is the equilibrium potential, and its magnitude is determined by the Nernst Equation. The Nernst Equation is derived from Fick’s Law in the presence of a potential or from thermodynamics. The equilibrium potential is calculated for Na+, K+, and Cl−. How these individual ions determine the resting membrane potential is clarified by deriving the Goldman–Hodgkin–Katz current equation by integrating the Nernst–Planck Electrodiffusion Equation. The dependence of ionic currents on membrane potential is used to introduce slope and chord conductance, and this is used to derive the chord conductance equation for resting membrane potential. This chapter ends with the conventions for potential and current flow.}
} 

