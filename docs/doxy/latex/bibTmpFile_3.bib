@incollection{VollmerLimitsOfBiology:1995,
	title = {The limits of biology},
	editor = {Dag Prawitz and Brian Skyrms and Dag Westerståhl},
	series = {Studies in Logic and the Foundations of Mathematics},
	publisher = {Elsevier},
	address = {Amsterdam},
	volume = {134},
	pages = {659-676},
	year = {1995},
	booktitle = {Logic, Methodology and Philosophy of Science IX},
	issn = {0049-237X},
	doi = {https://doi.org/10.1016/S0049-237X(06)80068-6},
	url = {https://www.sciencedirect.com/science/article/pii/S0049237X06800686},
	author = {Gerhard Vollmer},
	abstract = {Publisher Summary
	This chapter discusses the limits of biology. In trying to specify where the limits of biology do in fact lie, it is worthwhile first to point out where they do not lie. The limits of biology do not lie where, for some time, they had been supposed to lie: biology is not imperfect physics. Philosophy of science has started mainly from physics as the paradigmatic science and was tempted to extend the standards developed to all sciences. The set of its objects and the area of applications are markedly smaller than that of physics and of physical laws. Biological laws are much more difficult to find than physical ones. Most biological laws seem to allow for exceptions, they are not universally valid even in the field of competence of biology. Predictions are difficult, in some cases, even completely impossible. Therefore, biological theories can be confirmed, but hardly refuted. According to Popper's criterion of falsifiability, a good empirical theory must be prone to being refuted by experience biology, and first of all, evolutionary biology would offer nothing, but at metaphysical research program. Biological theories are less mathematized and less axiomated than physical ones.}
}

